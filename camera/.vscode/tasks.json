{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Clangd Database",
            "type": "shell",
            "group": "build",
            "command": "bear",
            "args": [
                "--output", "compile_commands.json", "--",
                "env/build_commands.sh",
            ],
        },
        {
            "label": "Build VC4 Programs (QPU & VPU) with Docker",
            "type": "shell",
            "group": "build",
            "command": "${workspaceFolder}/env/build_vc4_vpu_qpu.sh",
        },
    ]
}